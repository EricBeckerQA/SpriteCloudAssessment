# Copy this file to .env and adjust as needed.
# The framework falls back to these public defaults when no .env is present,
# so the suite runs out-of-the-box while staying environment-ready.

# --- Base URLs ---
BASE_URL_UI=https://www.saucedemo.com
BASE_URL_API=https://dummyjson.com

# --- UI credentials (SauceDemo publishes these openly on its login page) ---
SAUCE_STANDARD_USER=standard_user
SAUCE_PASSWORD=secret_sauce

# --- API credentials (DummyJSON public demo user) ---
API_USERNAME=emilys
API_PASSWORD=emilyspass
